{
  "name": "@obsidian-workbench/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "obsidian-workbench-mcp": "./dist/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "pretest": "pnpm --filter @obsidian-workbench/shared build && pnpm --filter @obsidian-workbench/vault-core build && pnpm --filter @obsidian-workbench/mcp-app build",
    "start": "node dist/main.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@obsidian-workbench/shared": "workspace:*",
    "@obsidian-workbench/vault-core": "workspace:*",
    "zod": "^4.0.10"
  },
  "devDependencies": {
    "@types/express": "^5.0.3"
  }
}
